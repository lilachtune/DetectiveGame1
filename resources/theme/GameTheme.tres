[resource]
default_font_size = 20

Button/styles/normal = SubResource("BtnNormal")
Button/styles/hover = SubResource("BtnHover")
Button/styles/pressed = SubResource("BtnPressed")
Button/styles/disabled = SubResource("BtnDisabled")
Button/styles/focus = SubResource("BtnHover")
Button/colors/font_color = Color(0.93, 0.90, 1.0, 1)
Button/colors/font_hover_color = Color(1, 1, 1, 1)
Button/colors/font_pressed_color = Color(1, 1, 1, 1)
Button/colors/font_disabled_color = Color(0.5, 0.5, 0.55, 1)
Button/font_sizes/font_size = 22

Label/colors/font_color = Color(0.92, 0.90, 0.98, 1)
Label/colors/font_shadow_color = Color(0, 0, 0, 0.4)
Label/constants/shadow_offset_x = 1
Label/constants/shadow_offset_y = 1
Label/font_sizes/font_size = 20

Panel/styles/panel = SubResource("PanelBg")

PanelContainer/styles/panel = SubResource("PanelContainerBg")

ItemList/styles/panel = SubResource("ListBg")
ItemList/styles/selected = SubResource("ListSelected")
ItemList/styles/selected_focus = SubResource("ListSelected")
ItemList/colors/font_color = Color(0.9, 0.88, 0.96, 1)
ItemList/colors/font_selected_color = Color(1, 1, 1, 1)
ItemList/font_sizes/font_size = 18
ItemList/constants/v_separation = 6

HSlider/styles/slider = SubResource("SliderBg")
HSlider/styles/grabber_area = SubResource("SliderFill")
HSlider/styles/grabber_area_highlight = SubResource("SliderFill")

OptionButton/styles/normal = SubResource("BtnNormal")
OptionButton/styles/hover = SubResource("BtnHover")
OptionButton/styles/pressed = SubResource("BtnPressed")
OptionButton/styles/disabled = SubResource("BtnDisabled")
OptionButton/colors/font_color = Color(0.93, 0.90, 1.0, 1)
OptionButton/font_sizes/font_size = 20

RichTextLabel/colors/default_color = Color(0.9, 0.88, 0.96, 1)
RichTextLabel/font_sizes/normal_font_size = 18

; ── Тип-вариация "CloseButton" — используй theme_type_variation = "CloseButton"
; на кнопках-крестиках. Компактные отступы (2px) гарантируют, что кнопка
; не "вырастет" за пределы заданного прямоугольника, как происходит с
; обычной Button (у неё отступы темы 18px по бокам).
CloseButton/base_type = "Button"
CloseButton/styles/normal = SubResource("CloseBtnNormal")
CloseButton/styles/hover = SubResource("CloseBtnHover")
CloseButton/styles/pressed = SubResource("CloseBtnPressed")
CloseButton/styles/focus = SubResource("CloseBtnHover")
CloseButton/colors/font_color = Color(0.95, 0.85, 0.87, 1)
CloseButton/colors/font_hover_color = Color(1, 1, 1, 1)
CloseButton/colors/font_pressed_color = Color(1, 1, 1, 1)
CloseButton/font_sizes/font_size = 18

MenuPanel/base_type = "PanelContainer"
MenuPanel/styles/panel = SubResource("MenuPanelBg")

MenuButton/base_type = "Button"
MenuButton/styles/normal = SubResource("MenuBtnNormal")
MenuButton/styles/hover = SubResource("MenuBtnHover")
MenuButton/styles/pressed = SubResource("MenuBtnPressed")
MenuButton/styles/disabled = SubResource("MenuBtnDisabled")
MenuButton/styles/focus = SubResource("MenuBtnHover")
MenuButton/colors/font_color = Color(0.96, 0.94, 1.0, 1)
MenuButton/colors/font_hover_color = Color(1, 1, 1, 1)
MenuButton/colors/font_pressed_color = Color(1, 1, 1, 1)
MenuButton/colors/font_disabled_color = Color(0.55, 0.55, 0.6, 1)
MenuButton/font_sizes/font_size = 22

MenuTitle/base_type = "Label"
